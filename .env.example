# Optional: override the BSC RPC endpoint used for on-chain reads.
# Defaults to the keyless Binance data-seed node when unset.
# For higher reliability/rate limits, use a private endpoint from a
# provider like Alchemy, QuickNode, or Ankr (with your API key).
#
# Copy this file to ".env.local" and fill in your URL:
#   REACT_APP_BSC_RPC_URL=https://your-bsc-endpoint.example/your-api-key
REACT_APP_BSC_RPC_URL=
